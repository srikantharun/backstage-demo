<?xml version='1.0' ?>
<!--
  BuildGraph script for ${{values.projectName}}
  Generated by Team17 Backstage Self-Service Portal

  Usage:
    RunUAT BuildGraph -Script="Build/BuildGraph.xml" -Target="Full Build" -Set:ProjectName=${{values.projectName}}
-->
<BuildGraph xmlns="http://www.epicgames.com/BuildGraph" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <!-- Options -->
  <Option Name="ProjectName" DefaultValue="${{values.projectName}}" Description="Name of the project"/>
  <Option Name="Configuration" DefaultValue="${{values.buildConfiguration}}" Description="Build configuration"/>
  <Option Name="WithEditor" DefaultValue="true" Description="Build editor binaries"/>
  <Option Name="WithTests" DefaultValue="true" Description="Run automated tests"/>

  <!-- Platform definitions -->
  <Property Name="TargetPlatforms" Value="{%- for platform in values.targetPlatforms %}${{platform}}{%- if not loop.last %};{%- endif %}{%- endfor %}"/>

  <!-- Agents -->
  <Agent Name="Compile Agent" Type="CompileWin64">

    <!-- Compile Editor -->
    <Node Name="Compile Editor" Produces="#EditorBinaries" If="$(WithEditor)">
      <Compile Target="$(ProjectName)Editor" Platform="Win64" Configuration="Development" Tag="#EditorBinaries"/>
    </Node>

    <!-- Compile Game for each platform -->
{%- for platform in values.targetPlatforms %}
    <Node Name="Compile ${{platform}}" Produces="#${{platform}}Binaries" Requires="#EditorBinaries">
      <Compile Target="$(ProjectName)" Platform="${{platform}}" Configuration="$(Configuration)" Tag="#${{platform}}Binaries"/>
    </Node>
{%- endfor %}

  </Agent>

  <Agent Name="Cook Agent" Type="CookWin64">

    <!-- Cook content for each platform -->
{%- for platform in values.targetPlatforms %}
    <Node Name="Cook ${{platform}}" Produces="#${{platform}}CookedContent" Requires="#${{platform}}Binaries">
      <Cook Project="$(ProjectName)" Platform="${{platform}}" Tag="#${{platform}}CookedContent"/>
    </Node>
{%- endfor %}

  </Agent>

  <Agent Name="Test Agent" Type="TestWin64">

    <!-- Run automated tests -->
    <Node Name="Functional Tests" Produces="#TestResults" Requires="#EditorBinaries" If="$(WithTests)">
      <Command Name="RunUnrealTests" Arguments="-Project=$(ProjectName) -RunAllTests -ReportExportPath=TestResults"/>
    </Node>

  </Agent>

  <Agent Name="Package Agent" Type="PackageWin64">

    <!-- Package for each platform -->
{%- for platform in values.targetPlatforms %}
    <Node Name="Package ${{platform}}" Produces="#${{platform}}Package" Requires="#${{platform}}CookedContent;#TestResults">
      <Command Name="BuildCookRun" Arguments="-Project=$(ProjectName) -Platform=${{platform}} -Configuration=$(Configuration) -Stage -Archive -Package"/>
      <Tag Files="Saved/StagedBuilds/${{platform}}/**" With="#${{platform}}Package"/>
    </Node>
{%- endfor %}

  </Agent>

  <!-- Aggregates -->
  <Aggregate Name="Full Build" Requires="{%- for platform in values.targetPlatforms %}#${{platform}}Package{%- if not loop.last %};{%- endif %}{%- endfor %}"/>
  <Aggregate Name="Editor Only" Requires="#EditorBinaries"/>
  <Aggregate Name="Tests Only" Requires="#TestResults"/>

</BuildGraph>
